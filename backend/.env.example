# Copy to .env (optional). Without GEMINI_API_KEY the pipeline runs with a
# deterministic heuristic fallback so the whole stack still works end-to-end.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# These default to the docker-compose service names and rarely need changing.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/transactions
REDIS_URL=redis://redis:6379/0
